# TheOneKit ephemeral files — shipped with kit, not project-specific
# These are generated at runtime and should never be committed

# Session state (per-machine, per-session)
session-state/

# Telemetry logs (local only, submitted via /t1k:watzup)
telemetry/

# Auto-update cache marker
.update-check-cache

# Hook logs
hooks/.logs/

# Module update temp files
.*-update.zip

# Resolved config (CLI-generated, machine-specific)
.t1k-resolved-config.json
